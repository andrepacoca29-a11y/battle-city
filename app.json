{
  "name": "battle-city-multiplayer",
  "description": "Battle City NES clone - Multiplayer via Socket.io",
  "keywords": ["game", "socket.io", "battle-city", "multiplayer"],
  "repository": "https://github.com/andrepacoca29-a11y/battle-city",
  "success_url": "/",
  "env": {
    "NODE_ENV": {
      "description": "Environment mode",
      "value": "production"
    },
    "PORT": {
      "description": "Server port",
      "value": "8080"
    },
    "DB_PATH": {
      "description": "Path to SQLite database",
      "value": "./data/battle_city.db"
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT tokens",
      "value": "your-super-secret-jwt-key-change-in-production",
      "required": true
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "scripts": {
    "postdeploy": "npm start"
  }
}
